# ---- Image generation ------------------------------------------------------
# OpenAI API key for photoreal mockups (gpt-image-1).
# Get one at https://platform.openai.com/api-keys
# If absent: the app ships clearly-labeled placeholder mockups and everything
# else keeps working.
OPENAI_API_KEY=

# Which image provider to use. Currently: "openai" | "placeholder".
# Swappable — see lib/providers/image/.
IMAGE_PROVIDER=openai

# ---- Lead capture (GoHighLevel) -------------------------------------------
# GHL inbound webhook URL (Automation > Workflows > Inbound Webhook trigger).
# If absent: leads are appended to data/leads.local.json and a warning is logged.
GHL_WEBHOOK_URL=

# Optional secondary path: GHL API v2 create-contact.
GHL_API_KEY=
GHL_LOCATION_ID=

# ---- File delivery (Dropbox) ----------------------------------------------
# Dropbox access token (App Console > your app > Generate access token).
# If absent: job packages are written to output/jobs/{jobId}/ locally.
DROPBOX_ACCESS_TOKEN=

# ---- Misc ------------------------------------------------------------------
# Public base URL of the deployed app (used in the Webflow embed snippet).
NEXT_PUBLIC_APP_URL=http://localhost:3000
